# === Estudio de Video IA — backup repo .gitignore ===

# AI engine / models (huge, re-installable — NOT part of our code)
ComfyUI*/
*.7z
*.safetensors
*.ckpt
*.pth

# Python runtime
__pycache__/
*.pyc
.venv/
venv/
env/

# Runtime / logs
*.pid
*.log

# Rendered media output (reproducible — generated by the RTX 3070)
*.mp4
*.mp3
*.wav
*.avi
*.mov
*.mkv
